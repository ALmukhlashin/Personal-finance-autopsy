# SQLite (default — file dibuat di folder prisma/, tanpa Docker)
DATABASE_URL="file:dev.db"

# PostgreSQL (opsional: docker compose up -d + ubah provider di schema.prisma)
# DATABASE_URL="postgresql://pfa:pfa_secret@localhost:5432/personal_finance_autopsy?schema=public"

JWT_SECRET="change-this-to-a-long-random-secret-min-32-chars"
NODE_ENV="development"
